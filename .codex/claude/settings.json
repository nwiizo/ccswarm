{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(cargo *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git worktree *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(similarity-rs *)",
      "mcp__serena__*",
      "Agent(Explore)",
      "Agent(frontend-specialist)",
      "Agent(backend-specialist)",
      "Agent(devops-specialist)",
      "Agent(qa-specialist)",
      "Agent(rust-fix-agent)",
      "Agent(code-refactor-agent)",
      "Agent(architecture-reviewer)",
      "Agent(all-reviewer)",
      "Agent(review-fix-agent)"
    ],
    "deny": [
      "Bash(rm -rf /)*",
      "Bash(cargo publish*)",
      "Edit(.git/***)",
      "Edit(.env*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-agent-scope.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/format-code.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/audit-trail.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/audit-trail.sh"
          }
        ]
      }
    ]
  },
  "env": {
    "RUST_LOG": "info",
    "CCSWARM_AUDIT_ENABLED": "true"
  }
}
